{
  "name": "node-telegram-bot-api",
  "version": "2.0.0-alpha.0",
  "description": "Telegram Bot API - runtime-agnostic TypeScript client (v2). See redesign/ARCHITECTURE.md.",
  "type": "module",
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "sideEffects": [
    "./dist/node/debug.js"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "keywords": [
    "telegram",
    "telegram bot",
    "telegram bot api",
    "bot",
    "typescript",
    "edge",
    "cloudflare-workers"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test test/unit",
    "test:e2e": "bun test --timeout 300000 test/e2e",
    "typecheck:test": "tsc -p test/tsconfig.json --noEmit",
    "typecheck:examples": "tsc -p examples/tsconfig.json --noEmit",
    "lint:core": "node scripts/check-core-imports.mjs",
    "check:edge": "bun scripts/check-edge-bundle.mjs",
    "check": "tsc -p tsconfig.json --noEmit && npm run typecheck:test && npm run typecheck:examples && npm run lint:core && npm run check:edge && bun test test/unit",
    "generate:types": "bun scripts/api-parser.ts"
  },
  "author": "Yago Pérez <yagoperezs@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "bun": "^1.3.14",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yagop/node-telegram-bot-api.git"
  },
  "bugs": {
    "url": "https://github.com/yagop/node-telegram-bot-api/issues"
  },
  "homepage": "https://github.com/yagop/node-telegram-bot-api"
}
